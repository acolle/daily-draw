# Server
PORT=3006
SESSION_SECRET=change-me-to-something-random

# Users (set to real first names / nicknames)
USER1_NAME=anthony
USER1_PASS=yourpassword1
USER2_NAME=friend
USER2_PASS=yourpassword2

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=daily-draw
# Optional: if bucket has public access enabled, set this to skip presigned URLs
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
