{
  "name": "daily-draw",
  "version": "1.0.0",
  "description": "Daily drawing habit tracker with Cloudflare R2 storage",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --experimental-sqlite server.js\"",
    "build": "tsc && vite build",
    "start": "NODE_ENV=production node --experimental-sqlite server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.17.0",
    "@types/multer": "^1.4.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
